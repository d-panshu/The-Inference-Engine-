FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl build-essential && rm -rf /var/lib/apt/lists/*

# Step 1: Install the heaviest dependency first (Torch)
RUN pip install --no-cache-dir torch==2.2.1 --index-url https://download.pytorch.org/whl/cpu

# Step 2: Install the rest
RUN pip install --no-cache-dir ray[serve]==2.10.0 prometheus-client==0.20.0 httpx==0.27.0 ollama==0.1.8