{
  "title": "LLM Inference Engine",
  "uid": "llm-inference-v1",
  "schemaVersion": 38,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Time To First Token (P50 / P99)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(llm_inference_ttft_seconds_bucket[1m]))",
          "legendFormat": "P50 TTFT"
        },
        {
          "expr": "histogram_quantile(0.99, rate(llm_inference_ttft_seconds_bucket[1m]))",
          "legendFormat": "P99 TTFT"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 2,
      "title": "Tokens Per Second",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(llm_inference_tokens_total[1m])",
          "legendFormat": "tokens/sec"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": { "fixedColor": "green", "mode": "fixed" }
        }
      }
    },
    {
      "id": 3,
      "title": "Active Batch Size",
      "type": "stat",
      "gridPos": { "x": 0, "y": 8, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "llm_batch_size_current",
          "legendFormat": "active requests"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "red", "value": 4 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Queue Depth",
      "type": "stat",
      "gridPos": { "x": 6, "y": 8, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "llm_queue_depth",
          "legendFormat": "waiting requests"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 8 },
              { "color": "red", "value": 14 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Memory Usage",
      "type": "gauge",
      "gridPos": { "x": 12, "y": 8, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "llm_memory_usage_bytes",
          "legendFormat": "RAM"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 0,
          "max": 17179869184,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10737418240 },
              { "color": "red", "value": 13958643712 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "KV Cache Utilisation",
      "type": "gauge",
      "gridPos": { "x": 18, "y": 8, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "llm_kv_cache_utilization_ratio",
          "legendFormat": "KV cache"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "title": "Gateway Request Rate",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(llm_gateway_requests_total[1m])",
          "legendFormat": "{{ model }} stream={{ stream }}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "id": 8,
      "title": "Gateway P99 End-to-End Latency",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(llm_gateway_latency_seconds_bucket[1m]))",
          "legendFormat": "P99 e2e latency"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    }
  ]
}
